{
  "name": "agentpack-cursor-native-skeleton",
  "displayName": "AgentPack Readiness for Cursor",
  "description": "Skeleton for native AgentPack readiness checks in Cursor-style hosts.",
  "version": "0.0.0",
  "private": true,
  "publisher": "agentpack",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:agentpack.guard"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentpack.guard",
        "title": "AgentPack: Check Readiness"
      }
    ],
    "configuration": {
      "title": "AgentPack Readiness",
      "properties": {
        "agentpack.guardCommand": {
          "type": "string",
          "default": "agentpack doctor --agent cursor",
          "description": "Command to run before trusting packed AgentPack context."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  }
}
